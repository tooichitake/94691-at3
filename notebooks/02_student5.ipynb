plot_qualitative_samples(
    {"CE": m2_preds["ce_beam"], "CE→GRPO": m2_preds["grpo_beam"]},
    loaders_m2.test_eval.dataset,
    preset=DATA_CFG.image.presets[CFG_M2["data"]["transform_preset"]],
